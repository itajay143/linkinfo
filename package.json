{
  "name": "linkinfo",
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "dotenv -- yarn workspace @linkinfo/web dev",
    "web:build": "dotenv -- yarn workspace @linkinfo/web build",
    "web:start": "dotenv -- yarn workspace @linkinfo/web start",
    "update:browserslist-db": "npx update-browserslist-db@latest",
    "worker:dev": "dotenv -- yarn workspace @linkinfo/worker dev",
    "worker:start": "dotenv -- yarn workspace @linkinfo/worker start",
    "concurrently:dev": "concurrently \"dotenv -- yarn workspace @linkinfo/web dev\" \"dotenv -- yarn workspace @linkinfo/worker dev\"",
    "concurrently:start": "concurrently \"dotenv -- yarn workspace @linkinfo/web start\" \"dotenv -- yarn workspace @linkinfo/worker start\"",
    "prisma:deploy": "dotenv -- yarn workspace @linkinfo/prisma deploy",
    "prisma:dev": "dotenv -- yarn workspace @linkinfo/prisma dev",
    "prisma:generate": "yarn workspace @linkinfo/prisma generate",
    "prisma:studio": "yarn workspace @linkinfo/prisma studio",
    "format": "yarn workspaces run format",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "postinstall": "yarn workspace @linkinfo/web run postinstall && patch-package"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "patch-package": "^8.0.0"
  },
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-mmkv": "4.1.2",
    "react-native-nitro-modules": "0.34.1"
  }
}
